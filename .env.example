# URL вашего Pi-hole (v6.x — использует новый /api эндпоинт, не /admin/api.php)
PIHOLE_URL=http://192.168.1.7

# Пароль веб-интерфейса Pi-hole (используется для получения session id через /api/auth)
PIHOLE_PASSWORD=

# Публичный адрес, на котором сервер доступен снаружи (нужен только для
# /.well-known/oauth-authorization-server, см. README — Security model)
BASE_URL=https://pihole-mcp.example.com

# Bearer-токен для авторизации запросов к этому MCP-серверу.
# Сгенерируйте случайную строку, например: python3 -c "import secrets; print(secrets.token_hex(32))"
# Если оставить пустым — сервер будет отвечать без авторизации (только для локальной сети/VPN!).
MCP_SECRET=
