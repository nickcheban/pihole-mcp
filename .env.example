# URL of your Pi-hole (v6.x — uses the new /api endpoint, not /admin/api.php)
PIHOLE_URL=http://192.168.1.7

# Pi-hole web UI password (used to obtain a session id via /api/auth)
PIHOLE_PASSWORD=

# Public address this server is reachable at externally (only needed for
# /.well-known/oauth-authorization-server, see README — Security model)
BASE_URL=https://pihole-mcp.example.com

# Bearer token used to authorize requests to this MCP server.
# Generate a random string, e.g.: python3 -c "import secrets; print(secrets.token_hex(32))"
# If left empty, the server responds without checking auth (local network/VPN only!).
MCP_SECRET=
